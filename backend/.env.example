# Database
DATABASE_URL=sqlite:///./ai_tutor.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor_db

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tutor providers
# OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
# OPENROUTER_REFERER=https://yourdomain.com
# OPENROUTER_APP_TITLE=AI Tutor App
# GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# Local text-to-speech
TTS_PROVIDER=coqui
# PIPER_TTS_URL=http://localhost:5001/synthesize
# COQUI_TTS_URL=http://localhost:5002/api/tts
# KOKORO_API_URL=http://localhost:8880

# Hedra avatar video generation
# HEDRA_API_KEY=your-hedra-api-key
HEDRA_API_BASE_URL=https://api.hedra.com/web-app/public
HEDRA_VIDEO_MODEL_ID=d1dd37a3-e39a-4854-a298-6510289f9cf2
HEDRA_VIDEO_RESOLUTION=540p
HEDRA_VIDEO_ASPECT_RATIO=9:16
VIDEO_STORAGE_PATH=./uploads/generated_videos
MAX_AVATAR_VIDEO_DURATION_SECONDS=60
AVATAR_TTS_SPEED=1.08

# Daily tech briefing automation
ENABLE_DAILY_VIDEO_SCHEDULER=true
DAILY_VIDEO_RUN_ON_STARTUP=false
DAILY_VIDEO_HOUR=8
DAILY_VIDEO_MINUTE=0
DAILY_VIDEO_TIMEZONE=America/Chicago
TECH_UPDATES_LOOKBACK_DAYS=2
TECH_UPDATES_MAX_ITEMS=4
TECH_UPDATES_FEEDS=https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://feeds.arstechnica.com/arstechnica/index

# Ollama local LLM
# OLLAMA_BASE_URL=http://localhost:11434
# If the backend runs in Docker while Ollama runs on your host machine, use:
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# File upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_COURSE_FILE_SIZE=52428800

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
