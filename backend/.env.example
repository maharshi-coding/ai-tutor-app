# Database
DATABASE_URL=sqlite:///./ai_tutor.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor_db

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tutor providers
# OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
# OPENROUTER_REFERER=https://yourdomain.com
# OPENROUTER_APP_TITLE=AI Tutor App
# GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# Local text-to-speech
TTS_PROVIDER=auto
# PIPER_TTS_URL=http://localhost:5001/synthesize
# COQUI_TTS_URL=http://localhost:5002/api/tts
# KOKORO_API_URL=http://localhost:8880

# D-ID avatar video generation
# DID_API_KEY=your-d-id-api-key
DID_API_BASE_URL=https://api.d-id.com
DID_DEFAULT_VOICE=en-US-JennyNeural
DID_VOICE_PROVIDER=microsoft
DID_REQUEST_TIMEOUT_SECONDS=120

# Ollama local LLM
# OLLAMA_BASE_URL=http://localhost:11434
# If the backend runs in Docker while Ollama runs on your host machine, use:
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# File upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_COURSE_FILE_SIZE=52428800

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
