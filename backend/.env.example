# Database
# Easiest local dev (no Postgres required):
DATABASE_URL=sqlite:///./ai_tutor.db
#
# Postgres example (use when Postgres is running):
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor_db

# JWT Secret
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API Keys (users provide their own)
# OPENAI_API_KEY=your-openai-api-key
# HUGGINGFACE_API_KEY=your-huggingface-api-key

# OpenRouter (tried first for tutor chat; add key + optional headers)
# OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
# If chat fails with 401 or empty replies, set these (required for some keys):
# OPENROUTER_REFERER=https://yourdomain.com
# OPENROUTER_APP_TITLE=AI Tutor App

# Gemini (fallback for tutor chat)
# GEMINI_API_KEY=your-gemini-api-key

# Avatar Generation - Choose ONE option:

# Option 1: Replicate API (RECOMMENDED - cloud, high quality, no local setup)
# Get your API token from: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Local Stable Diffusion WebUI (requires running SD WebUI locally)
# SD_API_URL=http://127.0.0.1:7860
# For cartoon tutor avatars, use a model/checkpoint that supports stylized img2img output:
# SD_MODEL_CHECKPOINT=your-cartoon-friendly-checkpoint.safetensors

# Ollama local LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Voice generation
TTS_PROVIDER=auto
# PIPER_TTS_URL=http://localhost:5001/synthesize
# PIPER_DEFAULT_VOICE=en_US-lessac-medium
# COQUI_TTS_URL=http://localhost:5002/api/tts
# COQUI_DEFAULT_VOICE=tts_models/en/ljspeech/tacotron2-DDC
KOKORO_API_URL=http://localhost:8880
KOKORO_DEFAULT_VOICE=af_heart

# Talking avatar video
SADTALKER_API_URL=http://localhost:8870
# SADTALKER_REF_IMAGE=./uploads/avatars/default.png
ENABLE_VIDEO_COMPRESSION=true
FFMPEG_BINARY=ffmpeg
VIDEO_COMPRESSION_CRF=30

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB
MAX_COURSE_FILE_SIZE=52428800  # 50MB

# Server
HOST=0.0.0.0
PORT=8000
