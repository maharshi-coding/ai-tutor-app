# Database
# Easiest local dev (no Postgres required):
DATABASE_URL=sqlite:///./ai_tutor.db
#
# Postgres example (use when Postgres is running):
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor_db

# JWT Secret
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API Keys (users provide their own)
# OPENAI_API_KEY=your-openai-api-key
# HUGGINGFACE_API_KEY=your-huggingface-api-key

# OpenRouter (tried first for tutor chat; add key + optional headers)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
# If chat fails with 401 or empty replies, set these (required for some keys):
# OPENROUTER_REFERER=https://yourdomain.com
# OPENROUTER_APP_TITLE=AI Tutor App

# Gemini (fallback for tutor chat)
# GEMINI_API_KEY=your-gemini-api-key

# Avatar Generation - Choose ONE option:

# Option 1: Replicate API (RECOMMENDED - cloud, high quality, no local setup)
# Get your API token from: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Local Stable Diffusion WebUI (requires running SD WebUI locally)
# SD_API_URL=http://127.0.0.1:7860
# For better-looking faces, use a realistic checkpoint:
# SD_MODEL_CHECKPOINT=Realistic_Vision_V5.1_fp16.safetensors

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# Server
HOST=0.0.0.0
PORT=8000
